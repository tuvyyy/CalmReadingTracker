AI_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=30m
AI_SERVER_PORT=8787

# Optional paid fallback later:
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Web Push notifications on Vercel
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Vercel KV / Upstash Redis REST storage for push subscriptions
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional if calling /api/cron/study-reminder from an external cron service
CRON_SECRET=
